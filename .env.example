# ============================================
# VoiceVault AI - Environment Configuration
# Copy this file to `.env.local` for Next.js
# and configure the same keys in Supabase
# project settings for Edge Functions.
# ============================================

# ---------- Core Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://xlopbtdnoyxheqtwnwyg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Used by Edge Functions (service role must NOT be exposed to client)
SUPABASE_URL=https://xlopbtdnoyxheqtwnwyg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# If you connect directly from backend tools / worker
DATABASE_URL=postgresql://postgres:password@db.host:5432/postgres

# ---------- Third-party AI Providers ----------

# AssemblyAI (primary transcription engine)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Groq (Whisper large-v3 secondary engine)
GROQ_API_KEY=your-groq-api-key

# OpenAI (GPT-4o + embeddings)
OPENAI_API_KEY=your-openai-api-key

# Google Cloud (optional tertiary STT: chirp)
GOOGLE_APPLICATION_CREDENTIALS_JSON=your-google-credentials-json-or-path

# ---------- Caching / Queues / Rate limits ----------

# Redis / Upstash for job status, rate limiting, etc. (optional)
REDIS_URL=rediss://your-redis-url
REDIS_TOKEN=your-redis-token

# pg_cron / pgmq config is done inside Postgres; no env needed here.

# ---------- Frontend App Config ----------

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=VoiceVault AI

# WebSocket URL for live transcription viewer (if using a custom relay server)
NEXT_PUBLIC_LIVE_TRANSCRIBE_WS_URL=wss://your-live-relay.example.com

